{
  "name": "tengri-xc-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsgo --noEmit && vite build",
    "preview": "vite preview",
    "tsgo": "tsgo --noEmit",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt \"src/**/*.{ts,tsx}\" && prettier --write \"src/**/*.scss\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,tsx}\" && prettier --check \"src/**/*.scss\"",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@vis.gl/react-google-maps": "^1.8.3",
    "antd": "^6.3.7",
    "bincode-ts": "^1.0.0",
    "camelcase-keys": "^10.0.2",
    "clsx": "^2.1.1",
    "react": "npm:@faiwer/react@^19.0.4",
    "react-dom": "npm:@faiwer/react-dom@^19.0.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.15.0",
    "remark-gfm": "^4.0.1",
    "uplot": "^1.6.32",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260506.1",
    "@vitejs/plugin-react": "^6.0.1",
    "oxlint": "^1.63.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
