# Base URL of the tengri-xc Rust server, including any path prefix.
# Local dev (matches server/.env SERVER_ADDR=0.0.0.0:5757):
#   VITE_SERVER_URL=http://localhost:5757
# Production behind a reverse proxy on a sub-path:
#   VITE_SERVER_URL=https://example.com/api
VITE_SERVER_URL=

# Google Maps JavaScript API key. Restrict it to your dev/prod origins +
# the "Maps JavaScript API" only, and set a daily quota cap in the Google
# Cloud Console so a leak/spike can't run up the bill.
VITE_GOOGLE_MAPS_API_KEY=
