# Copy to `.env` and adjust values for local development.
# `.env` is gitignored; this file is the template that ships with the repo.

# Address the HTTP server binds to.
SERVER_ADDR=0.0.0.0:3000

# Tracing filter. Examples:
#   RUST_LOG=info
#   RUST_LOG=tengri_server=debug,tower_http=debug,axum::rejection=trace
RUST_LOG=tengri_server=debug,tower_http=info

# Postgres connection (local docker-compose default).
DATABASE_URL=postgres://tengri:tengri@localhost:5432/tengri

# Postgres for the integration test suite. Must be a *separate* database — the
# test harness drops & recreates the `public` schema on every `cargo test` run.
# Create it once per machine:
#   docker exec tengri-postgres createdb -U tengri tengri_test
TEST_DATABASE_URL=postgres://tengri:tengri@localhost:5432/tengri_test

# Optional: domain Leonardo used for `leonardo_*` cookies. After Tengri accepts
# a legacy `leonardo_data` autologin cookie, it sends expired `leonardo_*`
# cookies for this domain so the browser drops the old Leonardo login state.
# Set without a leading dot, e.g. `leo.example.com`; leave empty for host-only
# deletion.
LEONARDO_COOKIE_DOMAIN=
